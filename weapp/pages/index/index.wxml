<view class="page">
  <view class="hero">
    <view class="hero-head">
      <view>
        <view class="eyebrow">今日进度</view>
        <view class="title">10,000 步</view>
      </view>
      <view class="status-dot">{{joined ? '已加入' : '未加入'}}</view>
    </view>

    <view class="ring">
      <view class="ring-inner">
        <view class="steps">{{stepsText}}</view>
        <view class="target">目标 10,000 步</view>
      </view>
    </view>

    <view class="stats">
      <view>
        <text class="stat-value">{{progress}}%</text>
        <text class="stat-label">完成</text>
      </view>
      <view>
        <text class="stat-value">{{timeLeft}}</text>
        <text class="stat-label">剩余</text>
      </view>
    </view>
  </view>

  <view class="panel">
    <view class="panel-title">加入挑战</view>
    <view class="panel-copy">授权微信运动后，自动校验今日真实步数。</view>

    <input
      class="nickname"
      type="nickname"
      placeholder="微信昵称"
      value="{{nickName}}"
      bindblur="onNickNameInput"
    />

    <view class="stake-row">
      <view
        wx:for="{{stakes}}"
        wx:key="*this"
        class="stake {{stake === item ? 'active' : ''}}"
        bindtap="chooseStake"
        data-value="{{item}}"
      >¥{{item}}</view>
    </view>

    <button class="primary" bindtap="joinChallenge">加入挑战</button>
    <button class="secondary" bindtap="syncSteps">同步步数</button>
  </view>

  <view class="pool">
    <view>
      <view class="pool-label">激励池</view>
      <view class="pool-amount">¥{{pool}}</view>
    </view>
    <view class="pool-meta">
      <text>{{players}} 人参与</text>
      <text>{{lagging}} 人落后</text>
    </view>
  </view>

  <view class="rules">
    <view class="section-title">规则</view>
    <view class="rule-card">
      <view class="rule-index">01</view>
      <view class="rule-copy">
        <view class="rule-title">健康目标</view>
        <view class="rule-text">每天 23:59 前达到 10,000 步即为达标。目标是保持稳定运动，不鼓励过量刷步。</view>
      </view>
    </view>
    <view class="rule-card">
      <view class="rule-index">02</view>
      <view class="rule-copy">
        <view class="rule-title">真实校验</view>
        <view class="rule-text">加入或同步时授权微信运动，系统按今日真实步数更新排行榜。</view>
      </view>
    </view>
    <view class="rule-card">
      <view class="rule-index">03</view>
      <view class="rule-copy">
        <view class="rule-title">奖励方式</view>
        <view class="rule-text">达标者平分未达标挑战金；排行榜用于荣誉展示，奖金只看是否达标，避免为了名次过度运动。</view>
      </view>
    </view>
    <view class="rule-card">
      <view class="rule-index">04</view>
      <view class="rule-copy">
        <view class="rule-title">当前状态</view>
        <view class="rule-text">当前金额仅用于测试流程，不会真实扣款；正式支付、退款和奖励需接入合规结算。</view>
      </view>
    </view>
  </view>

  <view class="board">
    <view class="board-head">
      <view class="section-title">挑战榜</view>
      <view class="board-tabs">
        <view
          class="board-tab {{boardMode === 'today' ? 'active' : ''}}"
          bindtap="switchBoard"
          data-mode="today"
        >今日</view>
        <view
          class="board-tab {{boardMode === 'history' ? 'active' : ''}}"
          bindtap="switchBoard"
          data-mode="history"
        >历史</view>
      </view>
    </view>

    <view wx:if="{{boardMode === 'today'}}">
      <view wx:if="{{leaderboard.length === 0}}" class="empty">暂无参与者</view>
      <view wx:for="{{leaderboard}}" wx:key="openid" class="row">
        <view class="rank-icon {{item.rankClass}}">{{item.rankIcon}}</view>
        <view class="rank-number">{{item.rankNumber}}</view>
        <view class="person">
          <view class="name">{{item.nickName || '微信用户'}}</view>
          <view class="meta">{{item.steps}} 步 · ¥{{item.stake}}</view>
        </view>
        <view class="bonus {{item.bonus > 0 ? '' : 'muted'}}">¥{{item.bonus || 0}}</view>
      </view>
    </view>

    <view wx:if="{{boardMode === 'history'}}">
      <view wx:if="{{history.length === 0}}" class="empty">暂无历史记录</view>
      <view wx:for="{{history}}" wx:key="day" class="history-card">
        <view class="history-head">
          <view>
            <view class="history-day">{{item.label}}</view>
            <view class="history-meta">{{item.players}} 人参与 · {{item.reached}} 人达标</view>
          </view>
          <view class="history-badge">Top 3</view>
        </view>
        <view wx:for="{{item.top}}" wx:for-item="player" wx:key="openid" class="history-row">
          <view class="mini-rank">{{player.rankText}}</view>
          <view class="history-name">{{player.nickName || '微信用户'}}</view>
          <view class="history-steps">{{player.steps}} 步</view>
        </view>
      </view>
    </view>
  </view>
</view>
