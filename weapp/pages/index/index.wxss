.page {
  min-height: 100vh;
  padding: 0 32rpx 56rpx;
  background: #f5f5f7;
}

button {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

button::after {
  border: 0;
}

.hero {
  position: relative;
  margin: 0 -32rpx;
  padding: 42rpx 32rpx 44rpx;
  overflow: hidden;
  color: #f7fff9;
  background: linear-gradient(180deg, #2f8a63 0%, #17392f 100%);
}

.hero-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.hero-shade {
  position: absolute;
  inset: 0;
  background:
    linear-gradient(180deg, rgba(17, 39, 32, 0.42), rgba(17, 39, 32, 0.74)),
    rgba(12, 28, 23, 0.18);
}

.hero-head {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.eyebrow,
.pool-label {
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
  font-weight: 600;
}

.title {
  margin-top: 8rpx;
  font-size: 58rpx;
  font-weight: 800;
  letter-spacing: 0;
  line-height: 1.05;
}

.status-dot {
  min-width: 104rpx;
  height: 48rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.14);
  color: rgba(255, 255, 255, 0.86);
  font-size: 24rpx;
  font-weight: 700;
  line-height: 48rpx;
  text-align: center;
}

.ring {
  position: relative;
  z-index: 1;
  display: flex;
  width: 360rpx;
  height: 360rpx;
  margin: 42rpx auto 32rpx;
  align-items: center;
  justify-content: center;
  border: 20rpx solid rgba(152, 223, 178, 0.95);
  border-radius: 50%;
  box-shadow: inset 0 0 0 18rpx rgba(255, 255, 255, 0.12);
}

.ring-inner {
  text-align: center;
}

.steps {
  font-size: 72rpx;
  font-weight: 850;
  line-height: 1;
}

.target {
  margin-top: 14rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
}

.stats {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.stats > view {
  padding: 22rpx 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.12);
  backdrop-filter: blur(20rpx);
}

.stat-value,
.stat-label,
.pool-meta text {
  display: block;
}

.stat-value {
  font-size: 38rpx;
  font-weight: 800;
}

.stat-label {
  margin-top: 6rpx;
  color: rgba(255, 255, 255, 0.68);
  font-size: 24rpx;
}

.panel,
.pool,
.rules,
.row,
.empty {
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(30, 38, 34, 0.08);
}

.panel {
  margin-top: -26rpx;
  padding: 34rpx;
}

.panel-title,
.section-title {
  color: #111814;
  font-size: 34rpx;
  font-weight: 800;
}

.panel-copy {
  margin-top: 10rpx;
  color: #747b76;
  font-size: 25rpx;
  line-height: 1.48;
}

.nickname {
  height: 92rpx;
  margin-top: 28rpx;
  padding: 0 26rpx;
  border: 0;
  border-radius: 22rpx;
  background: #f4f5f4;
  color: #111814;
  font-size: 29rpx;
}

.stake-row {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 8rpx;
  margin: 24rpx 0;
  padding: 8rpx;
  border-radius: 24rpx;
  background: #f1f3f1;
}

.stake {
  display: flex;
  height: 76rpx;
  align-items: center;
  justify-content: center;
  border-radius: 18rpx;
  background: transparent;
  color: #111814;
  font-size: 30rpx;
  font-weight: 800;
}

.stake.active {
  background: #fff;
  color: #26724f;
  box-shadow: 0 8rpx 20rpx rgba(28, 45, 36, 0.08);
}

.custom-stake {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 16rpx;
  align-items: center;
  height: 86rpx;
  margin: -6rpx 0 24rpx;
  padding: 0 24rpx;
  border-radius: 22rpx;
  background: #f4f5f4;
  color: #6a736e;
  font-size: 26rpx;
  font-weight: 700;
}

.custom-stake-input {
  height: 86rpx;
  color: #111814;
  font-size: 30rpx;
  font-weight: 800;
  text-align: right;
}

.primary,
.secondary {
  height: 92rpx;
  border-radius: 22rpx;
  font-size: 30rpx;
  font-weight: 800;
  line-height: 92rpx;
}

.primary {
  background: #2f8a63;
  color: #fff;
  box-shadow: 0 16rpx 32rpx rgba(47, 138, 99, 0.22);
}

.secondary {
  margin-top: 14rpx;
  border: 1rpx solid rgba(17, 24, 20, 0.1);
  background: #fff;
  color: #1d2924;
}

.pool {
  display: flex;
  margin-top: 28rpx;
  padding: 32rpx;
  align-items: center;
  justify-content: space-between;
  background: #151d19;
  color: #fff;
}

.pool-amount {
  margin-top: 8rpx;
  font-size: 56rpx;
  font-weight: 850;
  line-height: 1;
}

.pool-meta {
  display: grid;
  gap: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  text-align: right;
}

.board {
  margin-top: 34rpx;
}

.board-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.board-tabs {
  display: flex;
  padding: 6rpx;
  border-radius: 999rpx;
  background: #e9ece9;
}

.board-tab {
  min-width: 84rpx;
  height: 52rpx;
  border-radius: 999rpx;
  color: #66706a;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 52rpx;
  text-align: center;
}

.board-tab.active {
  background: #fff;
  color: #26724f;
  box-shadow: 0 6rpx 18rpx rgba(28, 45, 36, 0.08);
}

.rules {
  margin-top: 28rpx;
  padding: 32rpx;
}

.rule-card {
  display: flex;
  gap: 20rpx;
  margin-top: 22rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #f4f6f4;
}

.rule-index {
  display: flex;
  width: 52rpx;
  height: 52rpx;
  flex: 0 0 52rpx;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #e4f1e9;
  color: #26724f;
  font-size: 22rpx;
  font-weight: 850;
}

.rule-copy {
  min-width: 0;
}

.rule-title {
  color: #111814;
  font-size: 27rpx;
  font-weight: 800;
}

.rule-text {
  margin-top: 8rpx;
  color: #626a65;
  font-size: 25rpx;
  line-height: 1.5;
}

.row {
  display: grid;
  grid-template-columns: 42rpx 40rpx 1fr auto;
  gap: 14rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 24rpx;
}

.rank-icon {
  width: 42rpx;
  height: 42rpx;
  color: #9aa29d;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 42rpx;
  text-align: center;
}

.rank-icon.gold,
.rank-icon.silver,
.rank-icon.bronze {
  font-size: 34rpx;
}

.rank-number {
  color: #111814;
  font-size: 28rpx;
  font-weight: 850;
  text-align: center;
}

.person {
  min-width: 0;
}

.name {
  overflow: hidden;
  color: #111814;
  font-size: 29rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta {
  margin-top: 6rpx;
  color: #7a817d;
  font-size: 24rpx;
}

.bonus {
  color: #26724f;
  font-size: 30rpx;
  font-weight: 850;
}

.bonus.muted {
  color: #9aa29d;
}

.empty {
  margin-top: 18rpx;
  padding: 28rpx;
  color: #7a817d;
  font-size: 26rpx;
  text-align: center;
}

.history-card {
  margin-top: 18rpx;
  padding: 26rpx;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.94);
  box-shadow: 0 16rpx 44rpx rgba(30, 38, 34, 0.08);
}

.history-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 18rpx;
}

.history-day {
  color: #111814;
  font-size: 30rpx;
  font-weight: 850;
}

.history-meta {
  margin-top: 6rpx;
  color: #7a817d;
  font-size: 24rpx;
}

.history-badge {
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #e4f1e9;
  color: #26724f;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 44rpx;
}

.history-row {
  display: grid;
  grid-template-columns: 42rpx 1fr auto;
  gap: 14rpx;
  align-items: center;
  padding: 12rpx 0;
}

.mini-rank {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: #f1f3f1;
  color: #26724f;
  font-size: 22rpx;
  font-weight: 850;
  line-height: 36rpx;
  text-align: center;
}

.history-name {
  overflow: hidden;
  color: #111814;
  font-size: 26rpx;
  font-weight: 750;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.history-steps {
  color: #7a817d;
  font-size: 24rpx;
}
