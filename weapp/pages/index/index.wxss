.page {
  padding: 0 32rpx 48rpx;
}

.hero {
  margin: 0 -32rpx;
  padding: 40rpx 32rpx 52rpx;
  color: #fff;
  background: linear-gradient(180deg, #2f7d58, #1f2624);
}

.eyebrow {
  font-size: 24rpx;
  font-weight: 700;
  opacity: 0.74;
}

.eyebrow.dark {
  color: rgba(255, 255, 255, 0.72);
}

.title {
  margin-top: 8rpx;
  font-size: 72rpx;
  font-weight: 900;
  line-height: 1.05;
}

.ring {
  display: flex;
  width: 420rpx;
  height: 420rpx;
  margin: 64rpx auto 36rpx;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  border: 24rpx solid rgba(157, 226, 181, 0.9);
  border-radius: 50%;
  box-shadow: inset 0 0 0 18rpx rgba(255, 255, 255, 0.12);
}

.steps {
  font-size: 70rpx;
  font-weight: 900;
}

.target {
  margin-top: 10rpx;
  font-size: 26rpx;
  opacity: 0.8;
}

.stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.stats > view {
  padding: 24rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.13);
}

.stat-value,
.stat-label,
.pool-meta text {
  display: block;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 850;
}

.stat-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  opacity: 0.72;
}

.panel,
.pool,
.row {
  border-radius: 16rpx;
  background: #fffdf8;
  box-shadow: 0 18rpx 50rpx rgba(47, 42, 33, 0.12);
}

.panel {
  margin-top: -32rpx;
  padding: 34rpx;
}

.panel-head {
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
}

.panel-title,
.section-title {
  font-size: 36rpx;
  font-weight: 850;
}

.panel-copy {
  margin-top: 10rpx;
  color: #746d61;
  font-size: 26rpx;
  line-height: 1.45;
}

.pill {
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: rgba(47, 125, 88, 0.11);
  color: #2f7d58;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 48rpx;
}

.nickname {
  height: 92rpx;
  margin-top: 28rpx;
  padding: 0 22rpx;
  border: 1rpx solid rgba(24, 23, 19, 0.14);
  border-radius: 16rpx;
  background: #fff;
}

.stake-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 14rpx;
  margin: 24rpx 0;
}

.stake {
  height: 88rpx;
  border: 1rpx solid rgba(24, 23, 19, 0.14);
  border-radius: 16rpx;
  background: #fff;
  font-weight: 850;
}

.stake.active {
  border-color: rgba(47, 125, 88, 0.58);
  background: rgba(47, 125, 88, 0.1);
  color: #2f7d58;
}

.primary,
.secondary {
  height: 96rpx;
  border-radius: 16rpx;
  font-weight: 850;
}

.primary {
  background: #2f7d58;
  color: #fff;
}

.secondary {
  margin-top: 16rpx;
  border: 1rpx solid rgba(24, 23, 19, 0.14);
  background: #fff;
  color: #181713;
}

.pool {
  display: flex;
  margin-top: 28rpx;
  padding: 32rpx;
  justify-content: space-between;
  background: #1f2624;
  color: #fff;
}

.pool-amount {
  margin-top: 8rpx;
  font-size: 56rpx;
  font-weight: 900;
}

.pool-meta {
  display: grid;
  gap: 12rpx;
  align-content: center;
  color: rgba(255, 255, 255, 0.72);
  font-size: 26rpx;
  text-align: right;
}

.board {
  margin-top: 34rpx;
}

.row {
  display: grid;
  grid-template-columns: 64rpx 1fr auto;
  gap: 18rpx;
  align-items: center;
  margin-top: 18rpx;
  padding: 22rpx;
}

.rank {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(217, 154, 37, 0.14);
  color: #9a6511;
  font-size: 24rpx;
  font-weight: 850;
  line-height: 56rpx;
  text-align: center;
}

.name {
  font-size: 30rpx;
  font-weight: 850;
}

.meta {
  margin-top: 6rpx;
  color: #746d61;
  font-size: 24rpx;
}

.done {
  color: #2f7d58;
  font-size: 24rpx;
  font-weight: 850;
}

.done.risk {
  color: #d14b3f;
}
